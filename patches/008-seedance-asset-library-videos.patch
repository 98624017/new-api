+			name:   "already deleted",
+			status: model.TaskStatusSuccess,
+			data: map[string]any{
+				"model":   "seedance-asset",
+				"deleted": true,
+				"metadata": map[string]any{
+					"seedance": map[string]any{"kind": "asset", "resource_id": float64(123)},
+				},
+			},
+			want: "asset already deleted",
+		},
+	}
+
