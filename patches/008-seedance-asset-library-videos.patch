+func firstSeedanceAssetImageURL(req relaycommon.TaskSubmitReq) string {
+	if s := strings.TrimSpace(req.InputReference); s != "" {
+		return s
+	}
+	if s := strings.TrimSpace(req.Image); s != "" {
+		return s
+	}
+	for _, image := range req.Images {
