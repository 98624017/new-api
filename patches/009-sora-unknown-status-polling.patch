+			body: `{
+				"id": "video_123",
+				"object": "video",
+				"model": "seedance",
+				"status": "unknown",
+				"metadata": {
+					"url": "https://cdn.example.com/metadata-result.mp4"
+				}
+			}`,
+			url: "https://cdn.example.com/metadata-result.mp4",
+		},
+		{
+			name: "output video_url object",
+			body: `{
+				"id": "video_123",
+				"object": "video",
+				"model": "seedance",
+				"status": "unknown",
+				"output": {
+					"video_url": {
+						"url": "https://cdn.example.com/output-result.mp4"
+					}
+				}
+			}`,
+			url: "https://cdn.example.com/output-result.mp4",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
