+func TestParseTaskResultTreatsUnknownStatusWithResultURLAsSuccess(t *testing.T) {
+	adaptor := &TaskAdaptor{}
+
+	tests := []struct {
+		name string
+		body string
+		url  string
+	}{
+		{
+			name: "top-level video_url",
