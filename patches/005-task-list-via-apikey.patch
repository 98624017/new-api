+	total := model.TaskCountAllUserTokenTask(userId, tokenId, queryParams)
+	pageInfo.SetTotal(int(total))
+	pageInfo.SetItems(tasksToDto(items, false))
+	common.ApiSuccess(c, pageInfo)
+}
